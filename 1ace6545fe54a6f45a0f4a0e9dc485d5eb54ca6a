              </div>
            </div>
          </div>
        `;
      } else {
        mount.innerHTML = `
          <div class="controls">
            <div class="topBar">
              <div class="autoChip" id="autoCrowdBox">
                <span id="autoCrowdDot" class="dot"></span>
                <span class="autoText">
                  <span class="autoLabel">AUTO CROWD</span>
                  <span id="autoCrowdLabel">Detecting...</span>
                </span>
                <span id="autoCrowdTime" class="autoTime"></span>
              </div>
            </div>

            <div class="manualBar">
              <div class="select">
                <label for="timeSel">TIME</label>
                <select id="timeSel">
