    }

    function pad2(n){ return String(n).padStart(2,"0"); }
    function clamp(x,a,b){ return Math.max(a, Math.min(b, x)); }

    function fmtDateJST(d){
      const utc = d.getTime() + d.getTimezoneOffset()*60000;
      const jst = new Date(utc + (KYOTO.tz*3600000));
      const days = ["Sunday","Monday","Tuesday","Wednesday","Thursday","Friday","Saturday"];
      const mon  = ["Jan","Feb","Mar","Apr","May","Jun","Jul","Aug","Sep","Oct","Nov","Dec"];
      return `${days[jst.getDay()]}, ${mon[jst.getMonth()]} ${pad2(jst.getDate())} · ${pad2(jst.getHours())}:${pad2(jst.getMinutes())} (JST)`;
    }

    function crowdColor(level){
      if(level==="Very Low") return "#4A90E2";
      if(level==="Low") return "#3CB371";
      if(level==="Moderate") return "#F5A623";
      return "#E74C3C";
    }

    function calcSunset(date, lat, lon, tz){
      const rad = Math.PI/180;
      const day = Math.floor((Date.UTC(date.getFullYear(), date.getMonth(), date.getDate()) - Date.UTC(date.getFullYear(),0,0))/86400000);
      const lngHour = lon / 15;
      const t = day + ((18 - lngHour) / 24);

      const M = (0.9856 * t) - 3.289;
      let L = M + (1.916*Math.sin(M*rad)) + (0.020*Math.sin(2*M*rad)) + 282.634;
      L = (L + 360) % 360;

      let RA = Math.atan(0.91764*Math.tan(L*rad)) / rad;
      RA = (RA + 360) % 360;

      const Lquadrant  = Math.floor(L/90)*90;
      const RAquadrant = Math.floor(RA/90)*90;
      RA = RA + (Lquadrant - RAquadrant);
      RA = RA / 15;

      const sinDec = 0.39782*Math.sin(L*rad);
      const cosDec = Math.cos(Math.asin(sinDec));

      const zenith = 90.833;
      const cosH = (Math.cos(zenith*rad) - (sinDec*Math.sin(lat*rad))) / (cosDec*Math.cos(lat*rad));
      if(cosH > 1 || cosH < -1) return {hh:17, mm:30};

      let H = Math.acos(cosH)/rad;
      H = H / 15;

      const T = H + RA - (0.06571*t) - 6.622;
      let UT = T - lngHour;
      UT = (UT + 24) % 24;

      let localT = UT + tz;
      localT = (localT + 24) % 24;

      const hh = Math.floor(localT);
      const mm = Math.round((localT - hh) * 60);
      return {hh, mm: (mm===60?0:mm), carry:(mm===60?1:0)};
    }

    let liveWeather = null;
    async function fetchWeather(){
      try{
        const url = "https://api.open-meteo.com/v1/forecast"
          + `?latitude=${KYOTO.lat}&longitude=${KYOTO.lon}`
          + "&current=temperature_2m,weather_code"
          + "&hourly=precipitation_probability"
          + "&timezone=Asia%2FTokyo";

        const res = await fetch(url, {cache:"no-store"});
        const data = await res.json();

        const temp = data?.current?.temperature_2m;
        const probs = data?.hourly?.precipitation_probability || [];
        const times = data?.hourly?.time || [];
        let precipProb = null;

        if(times.length && probs.length){
          const nowStr = new Date().toISOString().slice(0,13);
          let idx = times.findIndex(t => t.startsWith(nowStr));
          if(idx < 0) idx = 0;
          precipProb = probs[idx];
        }

        liveWeather = { temp, precipProb };
      }catch(e){
        liveWeather = null;
      }
    }

    function comfortIndexFromTemp(t){
      if(t == null) return "—";
      if(t >= 22) return "Warm day";
      if(t >= 15) return "Mild";
      if(t >= 8)  return "Cool";
      return "Cold";
    }

    function weatherStrategyText(){
      if(!liveWeather) return "Check weather link before heading out.";
      const t = liveWeather.temp;
      const p = liveWeather.precipProb;
      const rainLikely = (p != null && p >= 50);

      if(rainLikely){
        return `Rain likely — covered/temple first, riverside short. (~${Math.round(t)}°C, ${p}% rain)`;
      }
      return `Dry / low rain — riverside first, then icons off-peak. (~${Math.round(t)}°C, ${p ?? "?"}% rain)`;
    }

    function getAutoCrowdLevel(){
      const now = new Date();
      const utc = now.getTime() + now.getTimezoneOffset()*60000;
      const jst = new Date(utc + KYOTO.tz*3600000);
      const h = jst.getHours();
      const dow = jst.getDay();

      let score = 0;
      if(h >= 7 && h < 10) score += 1;
      else if(h >= 10 && h < 16) score += 2;
      else if(h >= 16 && h < 20) score += 2;
      else score += 0;

      if(dow === 0 || dow === 6) score += 1;
      if(liveWeather?.precipProb != null && liveWeather.precipProb >= 60) score -= 1;

      score = clamp(score, 0, 3);
      if(score === 0) return "Very Low";
      if(score === 1) return "Low";
      if(score === 2) return "Moderate";
      return "High";
    }

    function updateAutoCrowdUI(){
      const level = getAutoCrowdLevel();
      const dot = document.getElementById("autoCrowdDot");
      const lab = document.getElementById("autoCrowdLabel");
      const tEl = document.getElementById("autoCrowdTime");

      if(dot) dot.style.background = crowdColor(level);
      if(lab) lab.innerText = level;

      const now = new Date();
      const utc = now.getTime() + now.getTimezoneOffset()*60000;
      const jst = new Date(utc + KYOTO.tz*3600000);
      if(tEl) tEl.innerText = `updated ${pad2(jst.getHours())}:${pad2(jst.getMinutes())}`;
    }

    function pickSpot(list, crowdLevel, timeKey){
      const crowdRank = {"Very Low":0,"Low":1,"Moderate":2,"High":3}[crowdLevel] ?? 2;
      const timeRank  = {"morning":0,"midday":1,"late":2,"night":3}[timeKey] ?? 1;

      let best = null;
      let bestScore = -999;
      for(const s of list){
        let risk = s.risk || "Moderate";
        const riskRank = {"Low":0,"Moderate":1,"High":2}[risk] ?? 1;

        let score = 0;
        score += (2 - riskRank) * (crowdRank >= 2 ? 2 : 1);
        score += (timeRank === 0 && (s.best||"").includes("morning")) ? 1 : 0;
        score += (timeRank === 3 && (s.best||"").includes("night")) ? 1 : 0;
        score += (timeRank === 2 && (s.best||"").includes("afternoon")) ? 1 : 0;
        if((s.walk || "").includes("min") && crowdRank >= 2) score += 1;

        if(score > bestScore){ bestScore = score; best = s; }
      }
      return best || list[0];
    }

    function bestTimeText(timeKey, crowdLevel){
      if(crowdLevel === "High"){
        if(timeKey === "midday") return "After 6:30 PM (cooler & calmer)";
        if(timeKey === "late")   return "Early morning tomorrow (7:00–9:00 AM)";
        if(timeKey === "night")  return "Anytime (icons earlier, riverside later)";
        return "Opening time (7:00–9:00 AM) is calmest";
      }
      if(crowdLevel === "Moderate"){
        if(timeKey === "midday") return "Late afternoon (after 4 PM)";
        if(timeKey === "late")   return "Late afternoon (golden hour)";
        if(timeKey === "night")  return "Night sakura (after dinner)";
        return "Morning (before 9 AM)";
      }
      return "Anytime (quiet today)";
    }

    function tipText(crowdLevel){
      if(crowdLevel === "High") return "Peak time now — choose nearby sakura spots first, then icons later.";
      if(crowdLevel === "Moderate") return "Balanced — avoid the busiest icons at midday.";
      return "Quiet hours — flexible timing (check transport / opening times).";
    }

    function suggestedFlow(crowdLevel){
      const rain = (liveWeather?.precipProb != null && liveWeather.precipProb >= 50);
      if(rain && crowdLevel !== "Very Low") return "Covered spots → Short riverside → Icons off-peak";
      if(crowdLevel === "High") return "Near STITCH first → Icons at opening time → Riverside at sunset";
      if(crowdLevel === "Moderate") return "Near STITCH → One icon → Photo spots near sunset";
      return "Riverside stroll → Nearby spots → Icon if you feel like it";
    }

    function bloomProgress(){
      const now = new Date();
      const start = new Date(PEAK_START + "T00:00:00+09:00");
      const end   = new Date(PEAK_END   + "T23:59:59+09:00");
      const mid   = new Date((start.getTime() + end.getTime())/2);

      const pct = clamp(((now - start) / (end - start)) * 100, 0, 100);
      const daysToMid = Math.ceil((mid - now) / 86400000);

      return { pct: Math.round(pct), midDays: daysToMid };
    }

    function setTags(elId, tags){
      const el = document.getElementById(elId);
      if(!el) return;
      el.innerHTML = "";
      for(const t of tags){
        const s = document.createElement("span");
        s.className = "tag";
        s.textContent = t;
        el.appendChild(s);
      }
    }

    function updateUI(){
      const timeSel = document.getElementById("timeSel");
      const crowdSel = document.getElementById("crowdSel");
      const timeKey = timeSel ? timeSel.value : "late";
      const crowdLevel = crowdSel ? crowdSel.value : "Moderate";

      document.getElementById("metaLine").innerText = fmtDateJST(new Date());

      document.getElementById("headerCrowdLabel").innerText = crowdLevel;
      document.getElementById("headerCrowdDot").style.background = crowdColor(crowdLevel);
      document.getElementById("headerCrowdHint").innerText = tipText(crowdLevel);

      document.getElementById("bestTime").innerText = bestTimeText(timeKey, crowdLevel);
      document.getElementById("bestTip").innerText = tipText(crowdLevel);

      const ss = calcSunset(new Date(), KYOTO.lat, KYOTO.lon, KYOTO.tz);
      const sunsetHH = (ss.hh + (ss.carry||0))%24;
      const sunsetMM = ss.mm;
      const sunsetStr = `${pad2(sunsetHH)}:${pad2(sunsetMM)}`;
      document.getElementById("sunsetStr").innerText = sunsetStr;

      const totalMin = sunsetHH*60 + sunsetMM;
      const a = totalMin - 35;
      const b = totalMin + 20;
      const aH = Math.floor((a+1440)%1440 / 60), aM = (a+1440)%1440 % 60;
      const bH = Math.floor((b+1440)%1440 / 60), bM = (b+1440)%1440 % 60;
      document.getElementById("photoWindow").innerText = `${pad2(aH)}:${pad2(aM)}–${pad2(bH)}:${pad2(bM)} (around sunset)`;

      const bp = bloomProgress();
      document.getElementById("bloomPct").innerText = `${bp.pct}%`;
      document.getElementById("peakWindow").innerText = `${PEAK_START} — ${PEAK_END}`;
      document.getElementById("countdown").innerText = `D-${Math.max(0,bp.midDays)}`;

      document.getElementById("weatherStrategy").innerText = weatherStrategyText();
      document.getElementById("comfortIndex").innerText = comfortIndexFromTemp(liveWeather?.temp);

      document.getElementById("suggestedFlow").innerText = suggestedFlow(crowdLevel);

      const near = pickSpot(NEAR_SPOTS, crowdLevel, timeKey);
      const icon = pickSpot(ICON_SPOTS, crowdLevel, timeKey);

      document.getElementById("nearTitle").innerText = `Near STITCH: ${near.name}`;
      document.getElementById("nearDesc").innerText = `${near.walk} · Best: ${near.best} · ${near.vibe}.`;
      setTags("nearTags", near.tags || []);

      document.getElementById("iconTitle").innerText = `Kyoto Icon: ${icon.name}`;
      document.getElementById("iconDesc").innerText = `${icon.travel} · Best: ${icon.best}.`;
      setTags("iconTags", icon.tags || []);

      document.getElementById("recoTitle").innerText = `Recommended now: ${near.name}`;
      document.getElementById("recoDesc").innerText = `Next: ${icon.name} (go off-peak). Flow: ${suggestedFlow(crowdLevel)}.`;
      document.getElementById("recoDot").style.background = crowdColor(crowdLevel);

      document.getElementById("btnWeather").href = WEATHER_URL;
      document.getElementById("btnSakura").href  = SAKURA_MAP_URL;
      document.getElementById("btnCrowd").href   = CROWD_MAP_URL;
      document.getElementById("btnInsta").href   = INSTAGRAM_URL;
    }

    async function init(){
      renderControls(CONTROLS_LAYOUT);

      document.getElementById("timeSel").addEventListener("change", updateUI);
      document.getElementById("crowdSel").addEventListener("change", updateUI);

      document.getElementById("btnRefresh").addEventListener("click", async ()=>{
        await fetchWeather();
        updateAutoCrowdUI();
        updateUI();
      });

      await fetchWeather();
      updateAutoCrowdUI();
      updateUI();

      setInterval(async ()=>{
        await fetchWeather();
        updateAutoCrowdUI();
        updateUI();
      }, 3600000);
    }

    init();
  </script>
</body>
</html>
