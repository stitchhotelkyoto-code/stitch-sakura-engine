  <script>
    /**********************************************************
     * ✅ 0) SETTINGS (여기만 너가 바꾸면 됨)
     **********************************************************/
    const CONTROLS_LAYOUT = "B"; // "A" or "B"

    const SAKURA_MAP_URL = "https://www.google.com/maps/d/u/0/viewer?mid=1d4bRtlPGDMOtNh13XdboeiLs5gIK_sk";
    const CROWD_MAP_URL = "https://platinumaps.jp/d/kyoto-smart-navi";
    const WEATHER_URL   = "https://forecast7.com/en/35d01135d77/kyoto/";
    const INSTAGRAM_URL = "https://www.instagram.com/stitchhotelkyoto/";

    const KYOTO = { lat: 35.0116, lon: 135.7681, tz: 9 };

    const PEAK_START = "2026-03-28";
    const PEAK_END   = "2026-04-05";

    const NEAR_SPOTS = [
      { name: "Takasegawa (Hotel-front Riverside)", walk: "5–12 min walk", best: "sunset / night sakura", vibe: "Riverside", tags:["Riverside","Quiet","Easy"], risk:"Low" },
