<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>STITCH Sakura Smart Guide</title>

  <style>
    :root{
      --bg: #fbf3f6;
      --card: rgba(255,255,255,0.86);
      --ink: #171717;
      --muted: rgba(23,23,23,0.62);
      --pink: #f3c7d4;
      --pink2: #f7dbe4;
      --line: rgba(23,23,23,0.10);
      --shadow: 0 18px 50px rgba(0,0,0,0.12);
      --radius: 22px;
    }

    *{ box-sizing:border-box; }
    html, body{ width:100%; overflow-x:hidden; }
    /* ✅ iOS 세로깨짐 예방 (기본 word-break 방지) */
    body, div, p, span, b, a, label{
      word-break: normal;
      overflow-wrap: normal;
    }

    body{
      margin:0;
      font-family: Georgia, "Times New Roman", serif;
      color: var(--ink);
      background:
        radial-gradient(1200px 500px at 20% 10%, rgba(243,199,212,0.55), transparent 60%),
        radial-gradient(900px 450px at 85% 15%, rgba(247,219,228,0.55), transparent 60%),
        linear-gradient(180deg, #fff, var(--bg));
      padding: 18px;
    }

    .wrap{
      max-width: 980px;
      width: min(980px, 100%);
      margin: 0 auto;
    }

    .card{
      width:100%;
      background: var(--card);
      border: 1px solid rgba(0,0,0,0.06);
      border-radius: var(--radius);
      box-shadow: var(--shadow);
      overflow: hidden;
    }

    .inner{
      padding: 22px 22px 18px;
    }

    .topBrand{
      font-size: 12px;
      letter-spacing: .12em;
      opacity: .65;
      text-transform: uppercase;
      margin-bottom: 6px;
    }

    .hero{
      display:flex;
      flex-direction:column;
      gap: 10px;
    }

    .heroTop{
      display:flex;
      align-items:flex-start;
      justify-content:space-between;
      gap: 14px;
      flex-wrap:wrap;
    }

    .h1{
      font-size: 46px;
      line-height: 1.02;
      margin: 0;
    }

    .meta{
      margin-top: 6px;
      font-size: 18px;
      opacity: .75;
    }

    .pill{
      display:flex;
      align-items:center;
      gap: 10px;
      padding: 10px 14px;
      border-radius: 999px;
      background: rgba(255,255,255,0.92);
      border: 1px solid rgba(0,0,0,0.08);
      box-shadow: 0 10px 30px rgba(0,0,0,0.06);
      min-height: 44px;
      white-space: nowrap;
      flex: 0 0 auto;
    }

    .dot{
      width:10px;
      height:10px;
      border-radius: 50%;
      background:#999;
      flex: 0 0 auto;
    }

    .muted{
      color: var(--muted);
    }

    /* ===== Controls ===== */
    .controls{
      display:flex;
      flex-direction:column;
      gap: 12px;
      margin-top: 14px;
    }

    .select{
      display:flex;
      flex-direction:column;
      gap: 6px;
      min-width: 200px;
    }

    label{
      font-size: 12px;
      letter-spacing: .12em;
      opacity: .65;
      text-transform: uppercase;
    }

    select{
      appearance:none;
      -webkit-appearance:none;
      border-radius: 999px;
      padding: 12px 14px;
      border: 1px solid rgba(0,0,0,0.10);
      background: rgba(255,255,255,0.95);
      font-family: inherit;
      font-weight: 700;
      cursor:pointer;
      min-width: 0;
    }

    .topBar, .manualBar{
      display:flex;
      gap: 12px;
      align-items:flex-end;
      flex-wrap: wrap;
    }

    .autoChip{
      display:flex;
      align-items:center;
      gap: 10px;
      padding: 12px 14px;
      border-radius: 999px;
      background: rgba(255,255,255,0.92);
      border: 1px solid rgba(0,0,0,0.08);
      box-shadow: 0 10px 30px rgba(0,0,0,0.06);
      min-height: 44px;
      flex: 1 1 320px;
      min-width: 0;
    }

    .autoText{
      display:flex;
      gap: 8px;
      align-items:center;
      font-weight: 800;
      min-width: 0;
    }

    .autoLabel{
      font-size: 12px;
      letter-spacing: .12em;
      opacity: .60;
      white-space: nowrap;
      flex: 0 0 auto;
    }

    .autoTime{
      margin-left:auto;
      font-size: 12px;
      opacity: .60;
      white-space: nowrap;
      flex: 0 0 auto;
    }

    /* Recommendation bar */
    .recoBar{
      margin-top: 10px;
      display:flex;
      align-items:flex-start;
      gap: 10px;
      padding: 12px 14px;
      border-radius: 16px;
      background: rgba(255,255,255,0.72);
      border: 1px solid rgba(0,0,0,0.06);
    }

    .recoTitle{ font-weight: 900; }
    .recoDesc{ opacity:.75; font-size: 14px; margin-top: 2px; }

    /* ===== Content grid ===== */
    .grid{
      display:grid;
      grid-template-columns: 1.45fr 1fr;
      gap: 14px;
      margin-top: 14px;
    }

    .panel{
      background: rgba(243,199,212,0.18);
      border: 1px solid rgba(0,0,0,0.06);
      border-radius: 18px;
      padding: 16px;
      overflow:hidden;
    }

    .panel h3{
      margin: 0 0 10px 0;
      font-size: 14px;
      letter-spacing: .12em;
      opacity: .7;
      text-transform: uppercase;
    }

    .big{
      font-size: 40px;
      font-weight: 900;
      line-height: 1.04;
      margin: 2px 0 6px 0;
    }

    .sub{
      opacity: .75;
      margin-bottom: 10px;
    }

    /* ✅ 칩 대신 KV Row (세로깨짐 방지 핵심) */
    .kvList{
      display:flex;
      flex-direction:column;
      gap: 10px;
      margin-top: 10px;
    }
    .kvRow{
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap: 12px;
      padding: 12px 14px;
      border-radius: 999px;
      background: rgba(255,255,255,0.92);
      border: 1px solid rgba(0,0,0,0.07);
      box-shadow: 0 6px 18px rgba(0,0,0,0.06);
      min-width: 0;
    }
    .kvL{
      display:flex;
      align-items:center;
      gap: 10px;
      min-width: 0;
    }
    .kvIcon{
      width: 22px;
      display:flex;
      justify-content:center;
      flex: 0 0 auto;
    }
    .kvName{
      font-weight: 800;
      white-space: nowrap;
      overflow:hidden;
      text-overflow: ellipsis;
      max-width: 60vw;
    }
    .kvV{
      font-weight: 700;
      opacity: .78;
      text-align:right;
      white-space: nowrap;     /* ✅ 줄바꿈 금지 */
      flex: 0 0 auto;          /* ✅ 폭 줄어들며 글자 쪼개지는거 방지 */
      min-width: 12ch;         /* ✅ 날짜/문장 세로깨짐 방지 */
    }
    .kvV.long{
      min-width: 18ch;
      font-weight: 600;
    }

    .listTitle{
      font-weight: 900;
      font-size: 28px;
      margin: 4px 0;
    }

    .mini{
      opacity:.78;
      margin: 0 0 10px 0;
    }

    .tags{
      display:flex;
      flex-wrap:wrap;
      gap: 8px;
      margin-top: 8px;
    }

    .tag{
      font-size: 13px;
      padding: 8px 10px;
      border-radius: 999px;
      background: rgba(255,255,255,0.75);
      border: 1px solid rgba(0,0,0,0.07);
      font-weight: 700;
      display:inline-flex;
      gap: 8px;
      align-items:center;
      white-space: nowrap;
    }

    .foot{
      padding: 14px 22px 20px;
      border-top: 1px solid rgba(0,0,0,0.06);
      display:flex;
      flex-direction:column;
      gap: 10px;
    }

    /* ✅ 버튼 “한 줄 유지” (모바일에서도 1줄 + 가로 스크롤) */
    .cta{
      display:flex;
      gap: 10px;
      align-items:center;
      flex-wrap: nowrap;        /* ✅ 2줄 금지 */
      overflow-x: auto;         /* ✅ 한 줄 유지하며 좌우 스크롤 */
      -webkit-overflow-scrolling: touch;
      padding-bottom: 6px;
      scrollbar-width: none;
    }
    .cta::-webkit-scrollbar{ display:none; }

    .btn{
      display:inline-flex;
      align-items:center;
      gap: 10px;
      padding: 12px 14px;
      border-radius: 999px;
      border: 1px solid rgba(0,0,0,0.10);
      background: rgba(255,255,255,0.90);
      text-decoration:none;
      color: var(--ink);
      font-weight: 900;
      box-shadow: 0 10px 24px rgba(0,0,0,0.06);
      white-space: nowrap;
      flex: 0 0 auto;
      min-width: 170px;
      justify-content:center;
    }

    /* ✅ Crowd map은 흰색(기본) */
    /* ✅ Instagram만 핑크 */
    .btn.insta{
      background: rgba(243,199,212,0.75);
      border-color: rgba(0,0,0,0.10);
    }

    /* Responsive */
    @media (max-width: 920px){
      .grid{ grid-template-columns: 1fr; }
      .h1{ font-size: 40px; }
      .kvName{ max-width: 56vw; }
    }

    @media (max-width: 720px){
      body{ padding: 12px; }
      .inner{ padding: 18px; }
      .h1{ font-size: 36px; }
      .topBar, .manualBar{ flex-direction:column; align-items:stretch; }
      .autoChip{ flex: 1 1 auto; }
      .autoTime{ margin-left:0; }
      .select{ min-width: unset; }
      .kvName{ max-width: 52vw; }
      .btn{ min-width: 160px; }
    }
  </style>
</head>

